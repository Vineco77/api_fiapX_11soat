# ==========================================
# Application
# ==========================================
NODE_ENV=development
PORT=your_api_port_here
API_VERSION=v1

# ==========================================
# Database (PostgreSQL)
# ==========================================
DB_USER=your_db_user_here
DB_PASSWORD=your_db_password_here
DB_NAME=your_db_name_here
DB_PORT=your_db_port_here

# Connection String (gerada automaticamente no docker-compose)
DATABASE_URL=postgresql://${DB_USER}:${DB_PASSWORD}@localhost:${DB_PORT}/${DB_NAME}?schema=public

# ==========================================
# Redis (Cache)
# ==========================================
REDIS_HOST=localhost
REDIS_PORT=your_redis_port_here

# ==========================================
# RabbitMQ (Message Queue)
# ==========================================
# Opção 1: Local (Docker)
RABBITMQ_HOST=localhost
RABBITMQ_PORT=your_rabbitmq_port_here
RABBITMQ_MANAGEMENT_PORT=your_rabbitmq_management_port_here
RABBITMQ_USER=your_rabbitmq_user_here
RABBITMQ_PASSWORD=your_rabbitmq_password_here


# ==========================================
# AWS S3 (Storage)
# ==========================================
AWS_REGION=your_aws_region_here
AWS_ACCESS_KEY_ID=your_aws_access_key_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key_here
AWS_S3_BUCKET=your_s3_bucket_name_here

# ==========================================
# Auth Service
# ==========================================
AUTH_GATE=your_auth_service_url_here
JWT_SECRET=your_shared_jwt_secret_here
MOCK_AUTH=false

# ==========================================
# Monitoring (Elasticsearch + Kibana)
# ==========================================
ELASTICSEARCH_HOST=localhost
ELASTICSEARCH_PORT=9200
ELASTICSEARCH_INDEX=api-fiapx-logs
KIBANA_PORT=5601
LOG_LEVEL=info

# ==========================================
# Application Config
# ==========================================
MAX_FPS=60
MAX_VIDEO_DURATION_MINUTES=10
SIGNED_URL_EXPIRATION_DAYS=7
MAX_VIDEOS_PER_REQUEST=10
MAX_FILE_SIZE_MB=500
CACHE_TTL_SECONDS=300
