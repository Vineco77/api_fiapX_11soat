# ==========================================
# Application
# ==========================================
NODE_ENV=development
PORT=3000
API_VERSION=v1

# ==========================================
# Database (PostgreSQL)
# ==========================================
DB_USER=fiap_user
DB_PASSWORD=fiap_password
DB_NAME=fiap_videos
DB_PORT=5432

# Connection String (gerada automaticamente no docker-compose)
DATABASE_URL=postgresql://${DB_USER}:${DB_PASSWORD}@localhost:${DB_PORT}/${DB_NAME}?schema=public

# ==========================================
# Redis (Cache)
# ==========================================
REDIS_HOST=localhost
REDIS_PORT=6379

# ==========================================
# RabbitMQ (Message Queue)
# ==========================================
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest

# ==========================================
# AWS S3 (Storage)
# ==========================================
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here
AWS_S3_BUCKET=your_bucket_name_here

# ==========================================
# Auth Service
# ==========================================
AUTH_SERVICE_URL=http://localhost:4000
JWT_SECRET=your_jwt_secret_here

# ==========================================
# Application Config
# ==========================================
MAX_FPS=60
MAX_VIDEO_DURATION_MINUTES=10
SIGNED_URL_EXPIRATION_DAYS=7
MAX_VIDEOS_PER_REQUEST=10
MAX_FILE_SIZE_MB=500
CACHE_TTL_SECONDS=300
